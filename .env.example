# Required Discord credentials
DISCORD_TOKEN=your-discord-bot-token

# Dashboard OAuth (optional if you do not expose the dashboard)
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
ADMIN_DISCORD_IDS=123456789012345678
DASHBOARD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
HEALTH_PORT=3000
NODE_ENV=development

# Social embeds are disabled until explicitly enabled and scoped.
SOCIAL_EMBEDS_ENABLED=false
TARGET_CHANNEL_IDS=123456789012345678,234567890123456789
REPLACEMENT_DOMAIN=fxtwitter.com
DELETE_ORIGINAL=false
USE_WEBHOOK=false
INCLUDE_ORIGINAL_AUTHOR=true

# Productivity
SUMMARIZER_ENABLED=true
CODE_HELPER_ENABLED=false
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Community features
# VOICE_HUB_CHANNEL_IDS=123456789012345678
# VOICE_HUB_ROOM_FORMAT=Voice - {user}
# The room panel needs View Channel, Send Messages, Read Message History,
# Manage Channels, Manage Roles, Move Members, and Create Instant Invite.
# Enable Guild Presence Intent for the current-game room-name option.
# STARBOARD_CHANNEL_ID=123456789012345678
# STARBOARD_THRESHOLD=3
# SUGGESTION_CHANNEL_ID=123456789012345678
# AUTO_THREAD_CHANNEL_IDS=123456789012345678

# Onboarding and moderation
# VERIFIED_ROLE_ID=123456789012345678
# WELCOME_CHANNEL_ID=123456789012345678
# VERIFICATION_PROMPT=Click the button below to verify and unlock the server roles!
# MOD_LOG_CHANNEL_ID=123456789012345678

# Greetings
# GREETING_JOIN_CHANNEL_ID=123456789012345678
# GREETING_LEAVE_CHANNEL_ID=123456789012345678
# GREETING_JOIN_MSG=👋 Welcome {user} to the server!
# GREETING_LEAVE_MSG=😢 {user} has left the server.
# GREETING_JOIN_DM=Thanks for joining our community!

# Optional Twitch feed API credentials
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
